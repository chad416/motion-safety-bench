    AXIS_HOMING             := 2,
    AXIS_DISCRETE_MOTION    := 3,
    AXIS_CONTINUOUS_MOTION  := 4,
    AXIS_STOPPING           := 5,
    AXIS_ERRORSTOP          := 6
);
END_TYPE
]]></Declaration>
  </DUT>
